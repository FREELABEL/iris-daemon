#!/usr/bin/env bash
# Resolve the REAL script location through any symlinks before computing BRIDGE_DIR.
# iris-bridge is a symlink at ~/.iris/bin/iris-bridge → ~/.iris/bridge/bridgectl; using
# "$0" directly would resolve BRIDGE_DIR to ~/.iris/bin and run ~/.iris/bin/index.js
# (which does not exist), so `iris-bridge start/restart` took the bridge down with no
# recovery (#136550). This portable loop follows the link chain (no GNU readlink -f).
SOURCE="${BASH_SOURCE[0]:-$0}"
while [ -h "$SOURCE" ]; do
    DIR="$(cd -P "$(dirname "$SOURCE")" && pwd)"
    SOURCE="$(readlink "$SOURCE")"
    [ "${SOURCE#/}" = "$SOURCE" ] && SOURCE="$DIR/$SOURCE"
done
BRIDGE_DIR="$(cd -P "$(dirname "$SOURCE")" && pwd)"
case "${1:-status}" in
    start)
        PID=$(lsof -ti :3200 2>/dev/null || true)
        if [ -n "$PID" ]; then echo "Bridge already running (PID: $PID)"; exit 0; fi
        nohup node "$BRIDGE_DIR/index.js" > "$BRIDGE_DIR/bridge.log" 2>&1 &
        sleep 2
        if curl -s "http://localhost:3200/health" > /dev/null 2>&1; then
            echo "Bridge started on http://localhost:3200 (PID: $!)"
        else
            echo "Failed to start. Check: cat $BRIDGE_DIR/bridge.log"; exit 1
        fi ;;
    stop)
        PID=$(lsof -ti :3200 2>/dev/null || true)
        if [ -n "$PID" ]; then kill "$PID" 2>/dev/null; echo "Stopped (PID: $PID)"
        else echo "Not running"; fi ;;
    restart) "$0" stop; sleep 1; "$0" start ;;
    status)
        if curl -s "http://localhost:3200/health" > /dev/null 2>&1; then
            echo "Running (PID: $(lsof -ti :3200 2>/dev/null || true))"
        else echo "Not running"; fi ;;
    logs) tail -f "$BRIDGE_DIR/bridge.log" ;;
    *) echo "Usage: iris-bridge {start|stop|restart|status|logs}" ;;
esac
